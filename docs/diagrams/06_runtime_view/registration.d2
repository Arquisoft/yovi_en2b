User Registration: {
    style: {
        font-size: 36
        bold: true
    }
    shape: sequence_diagram

    User: User {
        shape: person
        style: {
            fill: "#FFF3CD"
            stroke: "#E6A817"
            font-color: "#664D03"
        }
    }
    Frontend: Web Frontend (TS) {
        style: {
            fill: "#D4EDDA"
            stroke: "#28A745"
            font-color: "#155724"
        }
    }
    Backend: Web Application (TS) {
        style: {
            fill: "#CCE5FF"
            stroke: "#0D6EFD"
            font-color: "#002752"
        }
    }
    DB: Database {
        shape: cylinder
        style: {
            fill: "#F8D7DA"
            stroke: "#DC3545"
            font-color: "#721C24"
        }
    }

    User -> Frontend: Provide credentials
    Frontend -> Backend: Check credentials

    Backend -> DB: Query credentials
    DB -> Backend: Credentials {
        style: {
            stroke-dash: 3
        }
    }
    Backend -> Frontend: Registration result {
        style: {
            stroke-dash: 3
        }
    }
    Frontend -> User: Render result {
        style: {
            stroke-dash: 3
        }
    }
}