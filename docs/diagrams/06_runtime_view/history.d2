History Consultation: {
    style: {
        font-size: 36
        bold: true
    }
    shape: sequence_diagram

    User: Registered User {
        shape: person
        style: {
            fill: "#FFF3CD"
            stroke: "#E6A817"
            font-color: "#664D03"
        }
    }
    Frontend: Web Frontend (TS / React) {
        style: {
            fill: "#D4EDDA"
            stroke: "#28A745"
            font-color: "#155724"
        }
    }
    UsersService: users service (Node.js) {
        style: {
            fill: "#CCE5FF"
            stroke: "#0D6EFD"
            font-color: "#002752"
        }
    }
    DB: MariaDB {
        shape: cylinder
        style: {
            fill: "#F8D7DA"
            stroke: "#DC3545"
            font-color: "#721C24"
        }
    }

    User -> Frontend: Request match history
    Frontend -> UsersService: GET /users/api/history\n(Authorization: Bearer JWT)
    UsersService -> DB: Query match_records\nWHERE user_id = ?
    DB -> UsersService: Raw match records {
        style: {
            stroke-dash: 3
        }
    }
    UsersService -> Frontend: Match record list {
        style: {
            stroke-dash: 3
        }
    }
    Frontend -> Frontend: Compute display metrics\n(win rate, totals, etc.)
    Frontend -> User: Render history view {
        style: {
            stroke-dash: 3
        }
    }
}