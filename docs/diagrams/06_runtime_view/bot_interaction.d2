Bot API: {
    style: {
        font-size: 36
        bold: true
    }
    shape: sequence_diagram

    Bot: External Bot {
        shape: person
        style: {
            fill: "#FFF3CD"
            stroke: "#E6A817"
            font-color: "#664D03"
        }
    }
    Backend: Web Application (TS) {
        style: {
            fill: "#CCE5FF"
            stroke: "#0D6EFD"
            font-color: "#002752"
        }
    }
    Engine: Game Engine {
        style: {
            fill: "#E2D9F3"
            stroke: "#6F42C1"
            font-color: "#3B1F6E"
        }
    }

    Bot."Board state encoded in YEN notation"

    Bot -> Backend: play(boardState)
    Backend -> Engine: Request next move
    Engine -> Engine: Calculate next move
    Engine -> Backend: Return next move {
        style: {
            stroke-dash: 3
        }
    }
    Backend -> Bot: Next move (YEN notation) {
        style: {
            stroke-dash: 3
        }
    }
}