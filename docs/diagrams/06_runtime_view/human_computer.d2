Human vs Computer Match: {
    style: {
        font-size: 36
        bold: true
    }
    shape: sequence_diagram

    User: Human Player {
        shape: person
        style: {
            fill: "#FFF3CD"
            stroke: "#E6A817"
            font-color: "#664D03"
        }
    }
    Frontend: Web Frontend (TS) {
        style: {
            fill: "#D4EDDA"
            stroke: "#28A745"
            font-color: "#155724"
        }
    }
    Backend: Web Application (TS) {
        style: {
            fill: "#CCE5FF"
            stroke: "#0D6EFD"
            font-color: "#002752"
        }
    }
    Engine: Game Engine {
        style: {
            fill: "#E2D9F3"
            stroke: "#6F42C1"
            font-color: "#3B1F6E"
        }
    }
    DB: Database {
        shape: cylinder
        style: {
            fill: "#F8D7DA"
            stroke: "#DC3545"
            font-color: "#721C24"
        }
    }

    User -> Frontend: Select cell
    Frontend -> Backend: Perform move

    Backend -> Engine: Verify move
    Engine -> Backend: Validation / win status {
        style: {
            stroke-dash: 3
        }
    }

    If match has ended {
        Backend -> DB: Save match results
        DB -> Backend: Confirmation status {
            style: {
                stroke-dash: 3
            }
        }
    }

    Backend -> Frontend: Updated board state {
        style: {
            stroke-dash: 3
        }
    }
    Frontend -> User: Render result & status {
        style: {
            stroke-dash: 3
        }
    }
}